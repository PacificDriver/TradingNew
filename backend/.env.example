# Скопируйте в .env при локальном запуске бэкенда (без Docker)
DATABASE_URL=postgresql://mvp_user:mvp_password@localhost:55432/mvp_trading?schema=public
JWT_SECRET=supersecretjwtkey
PORT=4000
# CORS: origins с которых разрешены запросы. По умолчанию: localhost + https://aurabotrade.com
# FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001,https://aurabotrade.com
# Реферальная программа на отдельном домене — добавьте её URL для CORS
# REFERRAL_FRONTEND_ORIGIN=https://partners.yourdomain.com

# === HighHelp (пополнение и вывод) — обязательны для боевого режима ===
# Документация: https://docs.highhelp.io (ранее awesomedoc.highhelp.io)
# Получить PROJECT_ID и приватный ключ в личном кабинете мерчанта HighHelp.
#
# HIGHHELP_PROJECT_ID=57aff4db-b45d-42bf-bc5f-b7a499a01782
# HIGHHELP_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----"
# Публичный URL бэкенда (для колбеков и редиректа после оплаты). Без него платежи не работают.
# BACKEND_PUBLIC_URL=https://api.yourdomain.com
#
# Опционально:
# HIGHHELP_API_BASE=https://api.hh-processing.com
#
# Проверка колбеков (рекомендуется в проде):
# 1) Публичный ключ HighHelp (предпочтительно): ЛК → API → Настройки Callback → Public Key.
#    Скачайте ключ и вставьте в одну строку (с \n для переносов) или оставьте PEM как есть.
# HIGHHELP_CALLBACK_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"
#
# 2) Либо секрет: заголовок X-Webhook-Secret = секрет или X-HighHelp-Signature = HMAC-SHA256(body, секрет) в hex.
# HIGHHELP_WEBHOOK_SECRET=ваш_секрет

# Админ (скрипт create-admin): задайте свой пароль, иначе при первом запуске сгенерируется случайный
# ADMIN_EMAIL=admin@trading.local
# ADMIN_PASSWORD=ваш_надёжный_пароль_не_менее_12_символов

# === Telegram: уведомления о каждом изменении баланса и алерты по аномалиям ===
# Создайте бота через @BotFather, получите токен. Добавьте бота в группу/канал, получите Chat ID (например через @userinfobot в группе).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-1001234567890
# Пороги аномалий (опционально): крупная операция, много операций за 5 мин, большой приход за 1 мин
# TELEGRAM_ANOMALY_LARGE_AMOUNT=100000
# TELEGRAM_ANOMALY_RAPID_COUNT=15
# TELEGRAM_ANOMALY_SPIKE_AMOUNT=50000
