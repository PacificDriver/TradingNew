# Копируй сюда URL туннеля к БЭКЕНДУ (порт 4000), затем переименуй в .env.local или скопируй значения в .env.local
# Как получить: в отдельном терминале запусти   ngrok http 4000   и вставь выданный https://... URL ниже (без слэша в конце)

NEXT_PUBLIC_API_BASE_URL=https://ПОДСТАВЬ-URL-БЭКЕНДА.ngrok-free.app
NEXT_PUBLIC_WS_URL=wss://ПОДСТАВЬ-URL-БЭКЕНДА.ngrok-free.app
