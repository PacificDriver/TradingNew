# Режим разработки: только npm install, без build. next dev с hot reload.
FROM node:20-alpine

WORKDIR /app

COPY package.json tsconfig.json next.config.mjs tailwind.config.ts postcss.config.mjs next-env.d.ts ./
COPY app ./app
COPY components ./components
COPY store ./store
COPY lib ./lib

RUN npm install

EXPOSE 3000

CMD ["npm", "run", "dev"]
